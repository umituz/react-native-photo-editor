{
  "name": "@umituz/react-native-filesystem",
  "version": "2.1.16",
  "description": "File operations and import/export functionality for React Native apps",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "version:patch": "npm version patch -m 'chore: release v%s'"
  },
  "keywords": [
    "react-native",
    "filesystem",
    "file-system",
    "expo-file-system",
    "download",
    "file-operations"
  ],
  "author": "Ümit UZ <umit@umituz.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umituz/react-native-filesystem.git"
  },
  "peerDependencies": {
    "expo-file-system": ">=19.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "expo-file-system": "^19.0.21",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "typescript": "~5.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
